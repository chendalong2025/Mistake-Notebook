<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/addFragment">

    <fragment
        android:id="@+id/addFragment"
        android:name="com.mistakenotebook.ui.add.AddFragment"
        android:label="录入题目"/>

    <fragment
        android:id="@+id/questionBankFragment"
        android:name="com.mistakenotebook.ui.bank.QuestionBankFragment"
        android:label="题库"/>

    <fragment
        android:id="@+id/quizFragment"
        android:name="com.mistakenotebook.ui.quiz.QuizFragment"
        android:label="开始做题">
        <action
            android:id="@+id/action_quizFragment_to_resultFragment"
            app:destination="@id/resultFragment"
            app:popUpTo="@id/quizFragment"
            app:popUpToInclusive="true"/>
    </fragment>

    <fragment
        android:id="@+id/resultFragment"
        android:name="com.mistakenotebook.ui.result.ResultFragment"
        android:label="做题结果">
        <action
            android:id="@+id/action_resultFragment_to_quizFragment"
            app:destination="@id/quizFragment"
            app:popUpTo="@id/resultFragment"
            app:popUpToInclusive="true"/>
        <action
            android:id="@+id/action_resultFragment_to_addFragment"
            app:destination="@id/addFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true"/>
    </fragment>

</navigation>
