<?xml version="1.0" encoding="utf-8"?>
<!-- 根节点改为 FrameLayout：两个界面叠加，通过 visibility 切换 -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- 做题配置界面 -->
    <ScrollView android:id="@+id/layout_setup"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="开始做题" android:textSize="26sp" android:textStyle="bold"
                android:textColor="@color/text" android:gravity="center"
                android:layout_marginBottom="24dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="题目数量" android:textSize="22sp" android:textStyle="bold"
                android:textColor="@color/text" android:layout_marginBottom="8dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
                android:orientation="horizontal" android:layout_marginBottom="20dp">
                <Button android:id="@+id/btn_count_all" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1"
                    android:text="全部" android:textSize="22sp" android:textStyle="bold"
                    style="?attr/borderlessButtonStyle"/>
                <Button android:id="@+id/btn_count_100" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1"
                    android:text="100" android:textSize="22sp" android:textStyle="bold"
                    style="?attr/borderlessButtonStyle"/>
                <Button android:id="@+id/btn_count_50" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1"
                    android:text="50" android:textSize="22sp" android:textStyle="bold"
                    style="?attr/borderlessButtonStyle"/>
                <Button android:id="@+id/btn_count_20" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1"
                    android:text="20" android:textSize="22sp" android:textStyle="bold"
                    style="?attr/borderlessButtonStyle"/>
            </LinearLayout>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="每题时间" android:textSize="22sp" android:textStyle="bold"
                android:textColor="@color/text" android:layout_marginBottom="8dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
                android:orientation="horizontal" android:layout_marginBottom="32dp">
                <Button android:id="@+id/btn_time_5" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1"
                    android:text="5s" android:textSize="22sp" android:textStyle="bold"
                    style="?attr/borderlessButtonStyle"/>
                <Button android:id="@+id/btn_time_10" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1"
                    android:text="10s" android:textSize="22sp" android:textStyle="bold"
                    style="?attr/borderlessButtonStyle"/>
                <Button android:id="@+id/btn_time_15" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1"
                    android:text="15s" android:textSize="22sp" android:textStyle="bold"
                    style="?attr/borderlessButtonStyle"/>
                <Button android:id="@+id/btn_time_20" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1"
                    android:text="20s" android:textSize="22sp" android:textStyle="bold"
                    style="?attr/borderlessButtonStyle"/>
                <Button android:id="@+id/btn_time_30" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1"
                    android:text="30s" android:textSize="22sp" android:textStyle="bold"
                    style="?attr/borderlessButtonStyle"/>
                <Button android:id="@+id/btn_time_60" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1"
                    android:text="60s" android:textSize="22sp" android:textStyle="bold"
                    style="?attr/borderlessButtonStyle"/>
            </LinearLayout>

            <Button android:id="@+id/btn_start"
                android:layout_width="match_parent" android:layout_height="56dp"
                android:text="开始做题" android:textSize="20sp" android:textStyle="bold"
                android:backgroundTint="@color/primary" android:textColor="@color/white"/>
        </LinearLayout>
    </ScrollView>

    <!-- 做题界面（默认隐藏，开始做题后显示） -->
    <ScrollView android:id="@+id/layout_quiz"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView android:id="@+id/tv_progress"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="第 1 / 10 题" android:textSize="14sp"
                android:textColor="@color/text_muted" android:layout_marginBottom="4dp"/>
            <ProgressBar android:id="@+id/progress_bar"
                style="?android:progressBarStyleHorizontal"
                android:layout_width="match_parent" android:layout_height="8dp"
                android:max="100" android:progress="0"
                android:progressTint="@color/primary"
                android:layout_marginBottom="8dp"/>

            <TextView android:id="@+id/tv_countdown"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="10" android:textSize="48sp" android:textStyle="bold"
                android:textColor="@color/success"
                android:layout_gravity="end" android:layout_marginBottom="8dp"/>

            <TextView android:id="@+id/tv_question"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="" android:textSize="18sp" android:textColor="@color/text"
                android:background="@color/surface" android:padding="16dp"
                android:layout_marginBottom="16dp" android:minLines="3"/>

            <Button android:id="@+id/btn_opt_a"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:textSize="15sp" android:textColor="@color/text"
                android:backgroundTint="@color/btn_option"
                android:layout_marginBottom="6dp"
                android:gravity="start|center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"/>
            <Button android:id="@+id/btn_opt_b"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:textSize="15sp" android:textColor="@color/text"
                android:backgroundTint="@color/btn_option"
                android:layout_marginBottom="6dp"
                android:gravity="start|center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"/>
            <Button android:id="@+id/btn_opt_c"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:textSize="15sp" android:textColor="@color/text"
                android:backgroundTint="@color/btn_option"
                android:layout_marginBottom="6dp"
                android:gravity="start|center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"/>
            <Button android:id="@+id/btn_opt_d"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:textSize="15sp" android:textColor="@color/text"
                android:backgroundTint="@color/btn_option"
                android:layout_marginBottom="12dp"
                android:gravity="start|center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"/>

            <TextView android:id="@+id/tv_feedback"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="" android:textSize="16sp" android:textStyle="bold"
                android:gravity="center" android:layout_marginTop="8dp"/>
        </LinearLayout>
    </ScrollView>

</FrameLayout>
