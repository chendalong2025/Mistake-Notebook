<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="题目内容" android:textSize="13sp" android:textColor="@color/text_muted"
            android:layout_marginBottom="4dp"/>
        <EditText android:id="@+id/et_content"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:minLines="3" android:gravity="top" android:textSize="14sp"
            android:background="@color/background" android:padding="10dp"
            android:layout_marginBottom="12dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="四项选项（每个选项独占一行）" android:textSize="13sp"
            android:textColor="@color/text_muted" android:layout_marginBottom="4dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="44dp"
            android:orientation="horizontal" android:layout_marginBottom="4dp">
            <TextView android:layout_width="28dp" android:layout_height="match_parent"
                android:text="A." android:gravity="center" android:textSize="15sp"
                android:textStyle="bold" android:textColor="@color/text_muted"/>
            <EditText android:id="@+id/et_option_a"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:hint="选项A"
                android:textSize="14sp" android:background="@color/background" android:padding="10dp"/>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="44dp"
            android:orientation="horizontal" android:layout_marginBottom="4dp">
            <TextView android:layout_width="28dp" android:layout_height="match_parent"
                android:text="B." android:gravity="center" android:textSize="15sp"
                android:textStyle="bold" android:textColor="@color/text_muted"/>
            <EditText android:id="@+id/et_option_b"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:hint="选项B"
                android:textSize="14sp" android:background="@color/background" android:padding="10dp"/>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="44dp"
            android:orientation="horizontal" android:layout_marginBottom="4dp">
            <TextView android:layout_width="28dp" android:layout_height="match_parent"
                android:text="C." android:gravity="center" android:textSize="15sp"
                android:textStyle="bold" android:textColor="@color/text_muted"/>
            <EditText android:id="@+id/et_option_c"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:hint="选项C"
                android:textSize="14sp" android:background="@color/background" android:padding="10dp"/>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="44dp"
            android:orientation="horizontal" android:layout_marginBottom="12dp">
            <TextView android:layout_width="28dp" android:layout_height="match_parent"
                android:text="D." android:gravity="center" android:textSize="15sp"
                android:textStyle="bold" android:textColor="@color/text_muted"/>
            <EditText android:id="@+id/et_option_d"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:hint="选项D"
                android:textSize="14sp" android:background="@color/background" android:padding="10dp"/>
        </LinearLayout>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="正确答案" android:textSize="13sp" android:textColor="@color/text_muted"
            android:layout_marginBottom="4dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="44dp"
            android:orientation="horizontal">
            <Button android:id="@+id/btn_a" android:layout_width="0dp"
                android:layout_height="match_parent" android:layout_weight="1"
                android:text="A" android:textSize="16sp" android:textStyle="bold"
                style="?attr/borderlessButtonStyle"/>
            <Button android:id="@+id/btn_b" android:layout_width="0dp"
                android:layout_height="match_parent" android:layout_weight="1"
                android:text="B" android:textSize="16sp" android:textStyle="bold"
                style="?attr/borderlessButtonStyle"/>
            <Button android:id="@+id/btn_c" android:layout_width="0dp"
                android:layout_height="match_parent" android:layout_weight="1"
                android:text="C" android:textSize="16sp" android:textStyle="bold"
                style="?attr/borderlessButtonStyle"/>
            <Button android:id="@+id/btn_d" android:layout_width="0dp"
                android:layout_height="match_parent" android:layout_weight="1"
                android:text="D" android:textSize="16sp" android:textStyle="bold"
                style="?attr/borderlessButtonStyle"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
