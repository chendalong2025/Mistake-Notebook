<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:orientation="horizontal"
    android:padding="8dp"
    android:background="@color/surface">

    <TextView android:id="@+id/tv_index"
        android:layout_width="32dp" android:layout_height="match_parent"
        android:gravity="center" android:textSize="13sp"
        android:textColor="@color/text_muted"/>

    <TextView android:id="@+id/tv_content"
        android:layout_width="0dp" android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center_vertical" android:textSize="14sp"
        android:textColor="@color/text" android:maxLines="2"
        android:ellipsize="end"/>

    <Button android:id="@+id/btn_delete"
        android:layout_width="40dp" android:layout_height="match_parent"
        android:text="X" android:textSize="14sp"
        android:backgroundTint="@android:color/transparent"
        android:textColor="@color/error"
        style="?attr/borderlessButtonStyle"/>
</LinearLayout>
